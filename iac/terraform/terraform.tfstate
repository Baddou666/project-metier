              {
                "data": "#cloud-config\r\nhostname: cloud-node-01\r\nmanage_etc_hosts: true\r\nusers:\r\n  - default\r\n  - name: ubuntu\r\n    groups:\r\n      - sudo\r\n    shell: /bin/bash\r\n    lock_passwd: false\r\n    ssh_authorized_keys:\r\n      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDvUY1VFgyVe1BZZ7oX2/lOXRLoubVUOGIo/VGTIi8S7 noadaz@DESKTOP-FF8H7R1\r\n      - ssh-rsa  root@fanida\r\n    sudo: ALL=(ALL) NOPASSWD:ALL\r\nssh_pwauth: true\r\nchpasswd:\r\n  expire: false\r\n  users:\r\n    - name: ubuntu\r\n      password: ubuntu\r\n      type: text\r\npackages:\r\n  - qemu-guest-agent\r\n  - curl\r\nruncmd:\r\n  - systemctl enable qemu-guest-agent\r\n  - systemctl start qemu-guest-agent\r\n  - bash -lc 'curl -fsSL https://tailscale.com/install.sh | sh \u0026\u0026 sudo tailscale up --auth-key=tskey-auth-kCBfC8iXbE11CNTRL-HKQxS6qECBVNk3mkUYbgAVjsWC69PLa32'",
                "file_name": "cloud_config.yaml",
                "resize": 0
              }
            ],
            "timeout_upload": 1800
