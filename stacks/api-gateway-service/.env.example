REDIS_HOST=redis-server
REDIS_INTERNAL_PORT=6379
REDIS_PASSWORD=

RATE_LIMIT_SERVICE_INTERNAL_PORT=8080

TOKEN_ROUTE_ID=token-manager-token-route

REAL_IP_HEADER=X-Real-IP
FORWARDED_CLIENT_IP_HEADER=X-Gateway-Client-Ip
TRUSTED_FORWARDED_HEADERS=X-Real-IP,X-Forwarded-For,X-Forwarded-Proto,X-Forwarded-Host,X-Forwarded-Port,Forwarded
AUTH_GATEWAY_SHARED_SECRET_HEADER=X-Gateway-Auth
IS_ANONYM_USER_HEADER=X-IS-USER-ANONYM

AUTH_GATEWAY_SHARED_SECRET=

PROXY_API_HOST=rate-limiting-service
PROXY_API_PORT=8080
PROXY_FE_HOST=ai-text-detector-frontend
PROXY_FE_PORT=3000

BACKEND_API_URL=https://ai-detect-dev
FRONTEND_ENV=production

TOKEN_MANAGER_SERVICE_URI=http://token-manager-service:8080
AI_DETECTOR_SERVICE_URI=http://ai-detector-service:8080
JWKS_SRC_URL=http://token-manager-service:8080/.well-known/jwks.json
